# AI Consulting Delivery OPC - Configuration File
# Copy this file to .env and fill in your actual values

# ============================================
# LLM API Keys
# ============================================
OPENAI_API_KEY=your-openai-api-key-here
CLAUDE_API_KEY=your-claude-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ============================================
# CRM Integration
# ============================================
PIPEDRIVE_API_KEY=your-pipedrive-api-key
PIPEDRIVE_COMPANY_DOMAIN=your-company.pipedrive.com

ZOHO_CRM_API_KEY=your-zoho-api-key
ZOHO_ORG_ID=your-zoho-org-id

# ============================================
# Infrastructure (AWS)
# ============================================
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name

# ============================================
# Payment Processing
# ============================================
STRIPE_API_KEY=your-stripe-api-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# ============================================
# Monitoring & Logging
# ============================================
DATADOG_API_KEY=your-datadog-api-key
DATADOG_APP_KEY=your-datadog-app-key
DATADOG_SITE=datadoghq.com

# ============================================
# Communication Tools
# ============================================
SLACK_BOT_TOKEN=your-slack-bot-token
SLACK_WEBHOOK_URL=your-slack-webhook-url

GMAIL_SENDER_EMAIL=your-email@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password

# ============================================
# Calendar Integration
# ============================================
CALENDLY_TOKEN=your-calendly-token
CALENDLY_USERNAME=your-username

# ============================================
# Application Settings
# ============================================
APP_ENV=development  # development, staging, production
DEBUG=true
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR

# ============================================
# Project Configuration
# ============================================
DEFAULT_INDUSTRY=ecommerce  # Default industry for testing
DEFAULT_CURRENCY=USD
DEFAULT_TIMEZONE=UTC

# ============================================
# Industry-Specific Settings
# ============================================

# Legal Industry
LEGAL_COMPLIANCE_LEVEL=high  # high, medium, low
GDPR_ENABLED=true
AML_ENABLED=true

# Healthcare Industry
HIPAA_ENABLED=true
HEALTHCARE_DATA_RETENTION_DAYS=2555  # 7 years

# Finance Industry
PCI_DSS_ENABLED=true
FINANCE_AUDIT_LOG_ENABLED=true